        "financingHeading": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "Financing Options",
              "hasLocalizedValue": "true"
            },
            "constantValueEnabled": true
          },
          "fontSize": 22,
          "fontColor": "#d3a335",
          "fontWeight": 400,
          "textTransform": "normal"
        },
        "financingImage": {
          "field": "",
          "constantValue": {
            "url": "https://cdcssl.ibsrv.net/ibimg/smb/150x31_80/webmgr/1o/u/o/_SHARED/carecredit.gif?47ad7afb5dfa6ee7cdf3e27561e5feb5",
            "width": 150,
            "height": 31
          },
          "constantValueEnabled": true
        },
        "financingBodyOne": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "CareCredit is here to help you pay for treatments and procedures your insurance doesn’t cover. We offer No Interest* financing or low minimum monthly payment options so you can get what you want, when you want it. You can even use CareCredit for your family and favorite pet.",
              "hasLocalizedValue": "true"
            },
            "constantValueEnabled": true
          },
          "fontSize": 15,
          "fontColor": "#4a4a4a",
          "fontWeight": 400,
          "textTransform": "normal"
        },
        "financingBodyTwo": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "With three simple steps, including an instant approval process, it’s easy to apply for CareCredit. After you’re approved, you’re free to use CareCredit for the services you choose including LASIK, veterinary, dentistry, cosmetic, hearing aids and more.",
              "hasLocalizedValue": "true"
            },
            "constantValueEnabled": true
          },
          "fontSize": 15,
          "fontColor": "#4a4a4a",
          "fontWeight": 400,
          "textTransform": "normal"
        },
        "financingBodyThree": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "CareCredit is endorsed by some of the most credible organizations specific to each healthcare profession we support. And CareCredit is a GE Money Company, so you know you can count on us. For over 20 years, we’ve been helping over five million cardholders get the healthcare treatments they want and need.",
              "hasLocalizedValue": "true"
            },
            "constantValueEnabled": true
          },
          "fontSize": 15,
          "fontColor": "#4a4a4a",
          "fontWeight": 400,
          "textTransform": "normal"
        },
        "financingBodyFourBefore": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "Now you don’t have to worry about saving up for the procedures you want and need. With CareCredit, the decision’s in your hands to get what you want, when you want it. For more information or to apply online, visit",
              "hasLocalizedValue": "true"
            },
            "constantValueEnabled": true
          },
          "fontSize": 15,
          "fontColor": "#4a4a4a",
          "fontWeight": 400,
          "textTransform": "normal"
        },
