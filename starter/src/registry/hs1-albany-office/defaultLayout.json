        },
        "paymentBody": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "We accept checks, cash or credit cards. We also offer a flexible payment plan. Please see our Financial Coordinator for details. We are happy to file insurance for your reimbursement as long as you are free to choose your own dentist.",
              "hasLocalizedValue": "true"
