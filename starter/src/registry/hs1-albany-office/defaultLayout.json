        },
        "appointmentsBodyAfter": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "a simple process via our Web site. If, for any reason you cannot keep a scheduled appointment, or will be delayed, please call us as soon as possible.",
