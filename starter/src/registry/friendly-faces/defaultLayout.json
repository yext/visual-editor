            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Yes. Families can call in the morning for same-day scheduling when clinically appropriate.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 16,
              "fontColor": "#5f7380",
              "fontWeight": 400,
              "textTransform": "normal"
            }
          },
          {
            "question": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Can I complete forms before our first appointment?",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 16,
              "fontColor": "#17313d",
              "fontWeight": 800,
              "textTransform": "normal"
            },
            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Yes. New-patient paperwork and intake details can be completed before your visit to keep check-in simple.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 16,
              "fontColor": "#5f7380",
              "fontWeight": 400,
              "textTransform": "normal"
            }
          },
          {
            "question": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Do teens have private conversation time with clinicians?",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 16,
              "fontColor": "#17313d",
              "fontWeight": 800,
              "textTransform": "normal"
            },
            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Yes. When age-appropriate, part of the visit can be structured to support more independent healthcare conversations.",
                  "hasLocalizedValue": "true"
