          "fontSize": 22,
          "fontColor": "#d3a335",
          "fontWeight": 400,
          "textTransform": "normal"
        },
        "emergencyText": {
          "text": {
            "field": "",
            "constantValue": {
              "defaultValue": "If you have a life-threatening or severe injury, call 911 or go directly to the nearest hospital emergency room. We can treat a variety of traumatic dental injuries, including teeth that have been chipped, moved, or knocked out entirely. Please call our office for assistance.",
