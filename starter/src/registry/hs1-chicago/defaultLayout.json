          "fontSize": 26,
          "fontColor": "#1f1a19",
          "fontWeight": 300,
          "textTransform": "normal"
        },
        "paragraphs": [
          {
            "body": {
              "text": {
                "field": "",
                "constantValue": {
                  "en": "Welcome! The dental professionals at Northside Dental are pleased to welcome you to our practice. We want all our patients to be informed decision makers and fully understand any health issues you face.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 15,
              "fontColor": "#5b5554",
              "fontWeight": 300,
              "textTransform": "normal"
            }
          },
          {
            "body": {
              "text": {
                "field": "",
                "constantValue": {
                  "en": "Our web site also provides background about our staff, office hours, insurance policies, appointment procedures, maps and directions. We know how hectic life can be and are committed to making our practice convenient and accessible.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 15,
              "fontColor": "#5b5554",
              "fontWeight": 300,
              "textTransform": "normal"
            }
          },
          {
            "body": {
              "text": {
                "field": "",
                "constantValue": {
                  "en": "Please take a few moments to look through this site to get a better feel for Northside Dental's capabilities and services. Thank you.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 15,
              "fontColor": "#5b5554",
              "fontWeight": 300,
              "textTransform": "normal"
            }
          }
        ]
      }
