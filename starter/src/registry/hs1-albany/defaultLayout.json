    {
      "type": "Hs1AlbanyWelcomeSection",
      "props": {
        "id": "Hs1AlbanyWelcomeSection-3f69686c-73dc-4d0a-a87a-dcae9077d3d2",
        "heading": {
          "text": {
            "field": "",
            "constantValue": {
              "en": "WELCOME TO OUR PRACTICE",
