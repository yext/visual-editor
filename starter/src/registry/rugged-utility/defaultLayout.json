            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Yes. Zipper, buckle, and binding assessments start at the service desk, and the team can explain what can be fixed in house.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 15,
              "fontColor": "#6d665b",
              "fontWeight": 400,
              "textTransform": "normal"
            }
          },
          {
            "question": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Do you stock seasonal snow gear year-round?",
                  "hasLocalizedValue": "true"
