                "constantValueEnabled": true
              },
              "fontSize": 16,
              "fontColor": "#181715",
              "fontWeight": 800,
              "textTransform": "normal"
            },
            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Snow hardware is most complete during the winter season, but essentials and outerwear remain available longer depending on demand.",
