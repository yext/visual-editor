            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Yes. Staff can help fit daypacks and overnight packs during store hours, with longer appointments on weekday evenings.",
                  "hasLocalizedValue": "true"
                },
                "constantValueEnabled": true
              },
              "fontSize": 15,
              "fontColor": "#6d665b",
              "fontWeight": 400,
              "textTransform": "normal"
            }
          },
          {
            "question": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Can I bring in gear for basic repair?",
                  "hasLocalizedValue": "true"
