              "fontSize": 16,
              "fontColor": "#101418",
              "fontWeight": 700,
              "textTransform": "normal"
            },
            "answer": {
              "text": {
                "field": "",
                "constantValue": {
                  "defaultValue": "Yes. The schedule supports online booking, and confirmation emails include arrival notes and studio etiquette details.",
